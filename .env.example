# Reddit API
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=social-listener/1.0

# Hacker News API (no credentials needed)
HN_POLL_INTERVAL=60

# Mock generator
MOCK_BRAND_ID=nike
MOCK_POSTS_PER_SECOND=10
MOCK_SPIKE_MULTIPLIER=10

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis
REDIS_URL=redis://localhost:6379